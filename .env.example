# CMS 首次启动时创建唯一管理员。生产环境必须使用独立强密码，并禁止提交真实值。
CMS_ADMIN_USERNAME=content-admin
CMS_ADMIN_PASSWORD=请替换为至少12位强密码
# 生产环境始终使用 Secure Cookie；本地 HTTPS 调试时可显式设为 true。
# CMS_COOKIE_SECURE=true

# 本地开发默认写入 .data/news-cms.sqlite；生产环境改为持久化挂载路径。
# CMS_DATABASE_PATH=/var/lib/zhdashi/news-cms.sqlite

# 生产环境使用托管 PostgreSQL 和对象存储。本地 SQLite 仅用于开发与验收。
# CMS_DATABASE_URL=postgresql://...
# Neon 在 Vercel Marketplace 绑定后通常自动注入 DATABASE_URL；应用同时支持 DATABASE_URL 与 CMS_DATABASE_URL，后者优先。
# DATABASE_URL=postgresql://...
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# 一键翻译采用兼容 Chat Completions 的服务；未配置时后台会给出明确提示，不会伪造翻译结果，也不阻止中文稿发布。
# CMS_TRANSLATION_API_URL=https://your-provider.example/v1/chat/completions
# CMS_TRANSLATION_API_KEY=your-secret
# CMS_TRANSLATION_MODEL=your-model

# 外部新媒体工作台导入签名密钥。只允许创建或更新草稿，禁止由外部系统直接发布。
# CMS_IMPORT_SIGNING_SECRET=replace-with-at-least-32-random-bytes
# 旧变量名仅用于迁移期兼容；值仍作为 HMAC 签名密钥使用，新部署请使用上面的变量名。
# CMS_IMPORT_SHARED_SECRET=legacy-signing-secret

# 官网线索中转。生产发布脚本会在首次部署时生成加密密钥和内部 worker 令牌。
# LEAD_DATA_ENCRYPTION_KEY=replace-with-32-byte-base64-or-64-hex-key
# LEAD_WORKER_TOKEN=replace-with-at-least-32-random-characters
# LEAD_OUTBOX_DATABASE_PATH=/www/zhangdashi-deploy/shared/data/lead-outbox.sqlite
# PUBLIC_SITE_ORIGIN=https://zhangdashi.ai

# 飞书企业自建应用机器人。允许名单使用英文逗号分隔，真实值只写入服务器共享 .env.local。
# FEISHU_BOT_APP_ID=cli_xxxxxxxxxxxxxxxx
# FEISHU_BOT_APP_SECRET=replace-with-feishu-app-secret
# FEISHU_BOT_ALLOWED_CHAT_IDS=oc_xxxxxxxxxxxxxxxx
# FEISHU_BOT_ALLOWED_USER_IDS=ou_xxxxxxxxxxxxxxxx
# FEISHU_BOT_ALERT_CHAT_ID=oc_xxxxxxxxxxxxxxxx

# 官网线索智能问数。DeepSeek 官方 API 兼容 OpenAI Chat Completions。
LEAD_QUERY_AI_PROVIDER=deepseek
LEAD_QUERY_AI_API_URL=https://api.deepseek.com
LEAD_QUERY_AI_MODEL=deepseek-v4-flash
# LEAD_QUERY_AI_TIMEOUT_MS=15000
# LEAD_QUERY_AI_API_KEY=replace-with-deepseek-api-key
