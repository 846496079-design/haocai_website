# CMS 首次启动时创建唯一管理员。生产环境必须使用独立强密码，并禁止提交真实值。
CMS_ADMIN_USERNAME=content-admin
CMS_ADMIN_PASSWORD=请替换为至少12位强密码
# 生产环境始终使用 Secure Cookie；本地 HTTPS 调试时可显式设为 true。
# CMS_COOKIE_SECURE=true

# 本地开发默认写入 .data/news-cms.sqlite；生产环境改为持久化挂载路径。
# CMS_DATABASE_PATH=/var/lib/zhdashi/news-cms.sqlite

# 生产环境使用托管 PostgreSQL 和对象存储。本地 SQLite 仅用于开发与验收。
# CMS_DATABASE_URL=postgresql://...
# Neon 在 Vercel Marketplace 绑定后通常自动注入 DATABASE_URL；应用同时支持 DATABASE_URL 与 CMS_DATABASE_URL，后者优先。
# DATABASE_URL=postgresql://...
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# 一键翻译采用兼容 Chat Completions 的服务；未配置时后台会给出明确提示，不会伪造翻译结果。
# CMS_TRANSLATION_API_URL=https://your-provider.example/v1/chat/completions
# CMS_TRANSLATION_API_KEY=your-secret
# CMS_TRANSLATION_MODEL=your-model

# 外部新媒体工作台导入签名密钥。只允许创建或更新草稿，禁止由外部系统直接发布。
# CMS_IMPORT_SIGNING_SECRET=replace-with-at-least-32-random-bytes
# 旧变量名仅用于迁移期兼容；值仍作为 HMAC 签名密钥使用，新部署请使用上面的变量名。
# CMS_IMPORT_SHARED_SECRET=legacy-signing-secret
